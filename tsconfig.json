{
  "include": ["src/**/*.ts", "api/**/*.ts"],
  "exclude": ["tests/**", "dist/**"],
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
